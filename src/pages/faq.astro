---
import Layout from '../layouts/Layout.astro'
import SectionHeading from '../components/SectionHeading.astro'

const categories = [
  {
    title: 'ご注文について',
    faqs: [
      { q: '1枚からでも注文できますか？', a: 'はい、1枚から承ります。刺繍・DTFプリントは1枚から、シルクスクリーンは30枚程度からが目安です。' },
      { q: '個人でも注文できますか？', a: 'もちろんです。個人のお客様からのご注文も大歓迎です。お名前入れ、チームユニフォーム、記念品など、お気軽にご相談ください。' },
      { q: 'デザインデータがないのですが…', a: '手書きのラフスケッチやイメージ写真からデータを作成いたします。お気軽にご相談ください。' },
      { q: '持ち込みの衣類に加工できますか？', a: 'はい、お客様がお持ちの衣類・製品への加工も承ります。素材や状態によっては対応できない場合もございますので、事前にご相談ください。' },
    ],
  },
  {
    title: '加工について',
    faqs: [
      { q: '刺繍とプリント、どちらがおすすめですか？', a: '高級感・耐久性を重視するなら刺繍、フルカラー・低コストを重視するならプリントがおすすめです。用途に応じてご提案しますので、お気軽にご相談ください。' },
      { q: '刺繍の最大サイズはどのくらいですか？', a: '機種により異なりますが、概ね30cm×40cm程度まで対応可能です。大きいサイズについてはご相談ください。' },
      { q: '色数に制限はありますか？', a: '刺繍は最大15色程度まで対応可能です。プリント（DTF・シルクスクリーン）はフルカラー対応です。' },
      { q: 'サンプルを作ってもらうことはできますか？', a: 'はい、量産前にサンプルを作成いたします。仕上がりをご確認いただいてから本生産に入ります。' },
    ],
  },
  {
    title: '納期・料金について',
    faqs: [
      { q: '納期はどのくらいですか？', a: '通常5〜10営業日程度です。加工内容・数量により変動しますので、お見積り時にご案内いたします。お急ぎの場合は特急対応（3営業日〜）もございます。' },
      { q: '見積りは無料ですか？', a: 'はい、お見積りは無料です。お電話・メールフォームからお気軽にご依頼ください。' },
      { q: '送料はかかりますか？', a: '納品時の送料は別途いただいております。お見積り時にあわせてご案内いたします。' },
    ],
  },
  {
    title: 'その他',
    faqs: [
      { q: '工場見学はできますか？', a: 'はい、事前にご連絡いただければ工場見学も承ります。実際の加工現場をご覧いただけます。' },
      { q: '駐車場はありますか？', a: 'はい、ございます。JR水戸線 新治駅からも徒歩2分です。' },
    ],
  },
]
import { url } from '../utils/paths'
---

<Layout title="よくある質問｜タグチ刺繍ネーム有限会社">

  <section class="relative h-48 md:h-64 flex items-center">
    <div class="absolute inset-0 bg-navy-800"></div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-8 w-full">
      <p class="text-sm text-gold-300 tracking-[0.2em] uppercase mb-2">FAQ</p>
      <h1 class="heading-accent text-2xl md:text-4xl text-white">よくある質問</h1>
    </div>
  </section>

  <section class="py-section-sm md:py-section">
    <div class="mx-auto max-w-[800px] px-4 md:px-8">
      {categories.map((cat, ci) => (
        <div class={`${ci > 0 ? 'mt-12 md:mt-16' : ''}`}>
          <h2 class="heading-accent text-lg md:text-xl text-navy-800 mb-6 pb-2 border-b-2 border-gold-300">
            {cat.title}
          </h2>
          <div class="space-y-3">
            {cat.faqs.map((faq, i) => (
              <details class="js-fade-in group bg-white rounded-lg border border-warm-200 overflow-hidden" style={`transition-delay: ${i * 40}ms`}>
                <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer hover:bg-warm-50 transition-colors list-none">
                  <span class="shrink-0 w-7 h-7 rounded-full bg-navy-800 text-gold-400 flex items-center justify-center text-xs font-bold">Q</span>
                  <span class="text-sm font-medium text-navy-800 flex-1">{faq.q}</span>
                  <svg class="w-5 h-5 text-warm-400 shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </summary>
                <div class="px-5 pb-4 pl-[52px]">
                  <p class="text-sm text-warm-700 leading-relaxed">{faq.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="py-section-sm md:py-section bg-navy-800">
    <div class="mx-auto max-w-[800px] px-4 md:px-8 text-center">
      <div class="js-fade-in">
        <h2 class="heading-accent text-xl md:text-2xl text-white mb-3">解決しない場合は</h2>
        <p class="text-navy-200 text-sm mb-6">お電話・フォームからお気軽にお問い合わせください。</p>
        <a href={url("/contact")} class="inline-flex items-center px-8 py-3.5 bg-gold-500 text-navy-950 font-medium rounded tracking-wider hover:bg-gold-400 transition-all duration-200 hover:-translate-y-px hover:shadow-md">
          お問い合わせ
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

</Layout>
