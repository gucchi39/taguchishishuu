---
import Layout from '../layouts/Layout.astro'
import SectionHeading from '../components/SectionHeading.astro'

const comparison = [
  { item: '質感', embroidery: '立体的・高級感', print: 'フラット・鮮やか' },
  { item: '耐久性', embroidery: '非常に高い（洗濯に強い）', print: '高い（加工方法による）' },
  { item: '色数', embroidery: '最大15色程度', print: 'フルカラー対応可' },
  { item: 'コスト（少量）', embroidery: 'やや高め', print: 'DTFなら低コスト' },
  { item: 'コスト（大量）', embroidery: '数量が多いほど割安', print: 'シルクスクリーンが割安' },
  { item: '最小ロット', embroidery: '1枚〜', print: '1枚〜（DTF）/ 30枚〜（シルク）' },
  { item: '向いている用途', embroidery: 'ユニフォーム・作業着・キャップ', print: 'Tシャツ・タオル・グッズ' },
]

const useCases = [
  { title: 'ユニフォーム・作業着', description: '会社名・ロゴの刺繍入れ。チームの一体感と信頼感を高めます。' },
  { title: 'スポーツチーム', description: 'チーム名・背番号・ワッペンなど。各種スポーツユニフォームに対応。' },
  { title: '記念品・ノベルティ', description: '卒業記念、イベント記念品など。名前入れで特別な一品に。' },
  { title: 'アパレルブランド', description: 'ブランドネーム・タグ・ワッペンの製作。小ロットから対応可能。' },
  { title: '学校・幼稚園', description: '体操着・スモック・帽子へのお名前刺繍。個人のお客様も歓迎。' },
  { title: '飲食店・サービス業', description: 'エプロン・コックコート・キャップへの店名・ロゴ入れ。' },
]

const services = [
  {
    id: 'embroidery',
    title: '刺繍加工',
    en: 'Embroidery',
    image: '/images/facility/embroidery-line.jpg',
    description: '多頭式・単頭式の刺繍機を合計14台保有。ユニフォーム、作業着、キャップなどへのロゴ・ネーム刺繍を得意としています。',
    features: ['立体感と高級感のある仕上がり', '多色対応（最大15色）', '小ロット1枚〜大量生産まで', 'オリジナルデザインのデータ作成可'],
  },
  {
    id: 'print',
    title: 'プリント加工',
    en: 'Print',
    image: '/images/facility/dryer.jpg',
    description: 'DTF・シルクスクリーン・UVプリンターを保有。用途・数量・素材に応じて最適なプリント方法をご提案します。',
    features: ['DTFプリント：小ロット・フルカラー対応', 'シルクスクリーン：量産・高耐久', 'UVプリント：立体物・グッズ製作', '転写プリントにも対応'],
  },
  {
    id: 'wappen',
    title: 'ワッペン製作',
    en: 'Patch',
    image: '/images/facility/wappen-sample.jpg',
    description: 'レーザーカッターによるヒートカットワッペン、ロック仕上げワッペンなど、多様な仕様に対応します。',
    features: ['ヒートカット（レーザー加工）', 'ロック仕上げ', 'アイロン接着加工', 'オリジナルデザイン対応'],
  },
  {
    id: 'name',
    title: 'ネーム加工',
    en: 'Name Label',
    image: '/images/facility/barudan-multi.jpg',
    description: 'アパレル製品の織りネーム・プリントネーム・下げ札など、ブランドの顔となるネームタグを製作します。',
    features: ['織りネーム', 'プリントネーム', '下げ札・タグ', 'サイズ表示・品質表示'],
  },
]
import { url } from '../utils/paths'
---

<Layout title="加工サービス｜タグチ刺繍ネーム有限会社">

  <section class="relative h-48 md:h-64 flex items-center">
    <div class="absolute inset-0">
      <img src={url("/images/facility/factory-work-02.jpg")} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-navy-800/70"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-8 w-full">
      <p class="text-sm text-gold-300 tracking-[0.2em] uppercase mb-2">Service</p>
      <h1 class="heading-accent text-2xl md:text-4xl text-white">加工サービス</h1>
    </div>
  </section>

  {services.map((svc, i) => (
    <section id={svc.id} class={`py-section-sm md:py-section ${i % 2 === 0 ? '' : 'bg-warm-50'}`}>
      <div class="mx-auto max-w-[1200px] px-4 md:px-8">
        <div class="js-fade-in grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
            <img src={url(svc.image)} alt={svc.title} class="w-full aspect-video object-cover rounded-lg" loading="lazy" />
          </div>
          <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
            <span class="text-sm text-warm-500 font-light tracking-[0.2em] uppercase">{svc.en}</span>
            <h2 class="heading-accent text-xl md:text-2xl text-navy-800 mt-1 mb-4">
              <span class="gold-underline">{svc.title}</span>
            </h2>
            <p class="text-warm-700 leading-relaxed mb-6">{svc.description}</p>
            <ul class="space-y-2">
              {svc.features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-warm-700">
                  <svg class="w-5 h-5 text-gold-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Comparison: Embroidery vs Print -->
  <section class="py-section-sm md:py-section bg-warm-50">
    <div class="mx-auto max-w-[900px] px-4 md:px-8">
      <SectionHeading en="Comparison" ja="刺繍 vs プリント 比較表" />
      <div class="js-fade-in bg-white rounded-lg border border-warm-200 overflow-x-auto">
        <table class="w-full text-sm min-w-[500px]">
          <thead>
            <tr class="bg-navy-800 text-white">
              <th class="px-4 py-3 text-left font-medium w-28"></th>
              <th class="px-4 py-3 text-left font-medium">刺繍</th>
              <th class="px-4 py-3 text-left font-medium">プリント</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-warm-100">
            {comparison.map((row) => (
              <tr class="hover:bg-warm-50 transition-colors">
                <td class="px-4 py-3 font-medium text-navy-800">{row.item}</td>
                <td class="px-4 py-3 text-warm-700">{row.embroidery}</td>
                <td class="px-4 py-3 text-warm-700">{row.print}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="py-section-sm md:py-section">
    <div class="mx-auto max-w-[1200px] px-4 md:px-8">
      <SectionHeading en="Use Cases" ja="こんな用途に使えます" />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {useCases.map((item, i) => (
          <div class="js-fade-in bg-white rounded-lg border border-warm-200 p-6 hover:shadow-md hover:border-gold-300 transition-all duration-200" style={`transition-delay: ${i * 60}ms`}>
            <h3 class="text-base font-bold text-navy-800 mb-2">{item.title}</h3>
            <p class="text-sm text-warm-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tips -->
  <section class="py-section-sm md:py-section bg-navy-50">
    <div class="mx-auto max-w-[800px] px-4 md:px-8">
      <SectionHeading en="Tips" ja="ご注文前に知っておきたいこと" />
      <div class="js-fade-in space-y-6">
        <div class="bg-white rounded-lg border border-warm-200 p-6">
          <h3 class="font-bold text-navy-800 mb-2">素材による仕上がりの違い</h3>
          <p class="text-sm text-warm-700 leading-relaxed">
            薄手の生地（Tシャツ素材など）に大きな刺繍を入れると、生地が引っ張られることがあります。厚手の生地（ポロシャツ・作業着・キャップなど）は刺繍に最適です。素材に不安がある場合はお気軽にご相談ください。
          </p>
        </div>
        <div class="bg-white rounded-lg border border-warm-200 p-6">
          <h3 class="font-bold text-navy-800 mb-2">データの準備について</h3>
          <p class="text-sm text-warm-700 leading-relaxed">
            ロゴデータ（AI・EPS・PDF・高解像度JPG/PNG）をご用意ください。手書きのラフスケッチからのデータ作成も承っております。
          </p>
        </div>
        <div class="bg-white rounded-lg border border-warm-200 p-6">
          <h3 class="font-bold text-navy-800 mb-2">個人のお客様へ</h3>
          <p class="text-sm text-warm-700 leading-relaxed">
            「1枚だけでも注文できますか？」──はい、もちろん承ります。お子様のお名前入れ、チームのユニフォーム、記念品など、個人のお客様も大歓迎です。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-section-sm md:py-section bg-navy-800">
    <div class="mx-auto max-w-[800px] px-4 md:px-8 text-center">
      <div class="js-fade-in">
        <h2 class="heading-accent text-xl md:text-2xl text-white mb-3">加工のご相談・お見積り</h2>
        <p class="text-navy-200 text-sm mb-6">最適な加工方法をご提案いたします。お気軽にお問い合わせください。</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={url("/contact")} class="inline-flex items-center px-8 py-3.5 bg-gold-500 text-navy-950 font-medium rounded tracking-wider hover:bg-gold-400 transition-all duration-200 hover:-translate-y-px hover:shadow-md">
            お問い合わせ
            <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href={url("/flow")} class="inline-flex items-center px-8 py-3.5 border border-navy-400 text-white rounded tracking-wider hover:bg-navy-700 transition-all duration-200">
            ご注文の流れ
            <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
