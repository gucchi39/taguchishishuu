---
import Layout from '../layouts/Layout.astro'
import SectionHeading from '../components/SectionHeading.astro'

const comparison = [
  { item: '質感', embroidery: '立体的・高級感', print: 'フラット・鮮やか' },
  { item: '耐久性', embroidery: '非常に高い（洗濯に強い）', print: '高い（加工方法による）' },
  { item: '色数', embroidery: '最大15色程度', print: 'フルカラー対応可' },
  { item: 'コスト（少量）', embroidery: 'やや高め', print: 'DTFなら低コスト' },
  { item: 'コスト（大量）', embroidery: '数量が多いほど割安', print: 'シルクスクリーンが割安' },
  { item: '最小ロット', embroidery: '1枚〜', print: '1枚〜（DTF）/ 30枚〜（シルク）' },
  { item: '向いている用途', embroidery: 'ユニフォーム・作業着・キャップ', print: 'Tシャツ・タオル・グッズ' },
]

const useCases = [
  { title: 'ユニフォーム・作業着', description: '会社名・ロゴの刺繍入れ。チームの一体感と信頼感を高めます。' },
  { title: 'スポーツチーム', description: 'チーム名・背番号・ワッペンなど。各種スポーツユニフォームに対応。' },
  { title: '記念品・ノベルティ', description: '卒業記念、イベント記念品など。名前入れで特別な一品に。' },
  { title: 'アパレルブランド', description: 'ブランドネーム・タグ・ワッペンの製作。小ロットから対応可能。' },
  { title: '学校・幼稚園', description: '体操着・スモック・帽子へのお名前刺繍。個人のお客様も歓迎。' },
  { title: '飲食店・サービス業', description: 'エプロン・コックコート・キャップへの店名・ロゴ入れ。' },
]

const services = [
  {
    id: 'embroidery',
    title: '刺繍加工',
    en: 'Embroidery',
    image: '/images/facility/embroidery-line.jpg',
    description: '多頭式・単頭式の刺繍機を合計14台保有。ユニフォーム、作業着、キャップなどへのロゴ・ネーム刺繍を得意としています。',
    features: ['立体感と高級感のある仕上がり', '多色対応（最大15色）', '小ロット1枚〜大量生産まで', 'オリジナルデザインのデータ作成可'],
  },
  {
    id: 'print',
    title: 'プリント加工',
    en: 'Print',
    image: '/images/facility/dryer.jpg',
    description: 'DTF・シルクスクリーン・UVプリンターを保有。用途・数量・素材に応じて最適なプリント方法をご提案します。',
    features: ['DTFプリント：小ロット・フルカラー対応', 'シルクスクリーン：量産・高耐久', 'UVプリント：立体物・グッズ製作', '転写プリントにも対応'],
  },
  {
    id: 'wappen',
    title: 'ワッペン製作',
    en: 'Patch',
    image: '/images/facility/wappen-sample.jpg',
    description: 'レーザーカッターによるヒートカットワッペン、ロック仕上げワッペンなど、多様な仕様に対応します。',
    features: ['ヒートカット（レーザー加工）', 'ロック仕上げ', 'アイロン接着加工', 'オリジナルデザイン対応'],
  },
  {
    id: 'name',
    title: 'ネーム加工',
    en: 'Name Label',
    image: '/images/facility/barudan-multi.jpg',
    description: 'アパレル製品の織りネーム・プリントネーム・下げ札など、ブランドの顔となるネームタグを製作します。',
    features: ['織りネーム', 'プリントネーム', '下げ札・タグ', 'サイズ表示・品質表示'],
  },
]

const positions = [
  { name: '左胸', desc: 'ロゴ・社名（最も人気）', size: '~8cm' },
  { name: '右胸', desc: '個人名・役職名', size: '~8cm' },
  { name: '背中（上部）', desc: '社名・チーム名', size: '~12cm' },
  { name: '背中（大）', desc: '大型ロゴ・デザイン', size: '~25cm' },
  { name: '袖', desc: 'ワッペン・ロゴ', size: '~8cm' },
  { name: 'キャップ正面', desc: 'ロゴ・チーム名', size: '~6cm' },
]

import { url } from '../utils/paths'
---

<Layout title="加工サービス｜タグチ刺繍ネーム有限会社">

  <section class="relative h-48 md:h-64 flex items-center">
    <div class="absolute inset-0">
      <img src={url("/images/facility/factory-work-02.jpg")} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-navy-800/70"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-8 w-full">
      <p class="text-sm text-gold-300 tracking-[0.2em] uppercase mb-2">Service</p>
      <h1 class="heading-accent text-2xl md:text-4xl text-white">加工サービス</h1>
      <p class="text-navy-200 text-sm mt-2">料金目安・加工方法・対応範囲をご案内します</p>
    </div>
  </section>

  <!-- Page anchor nav -->
  <nav class="bg-warm-50 border-b border-warm-200 sticky top-16 md:top-20 z-40">
    <div class="mx-auto max-w-[1200px] px-4 md:px-8 flex gap-1 overflow-x-auto py-3">
      {services.map((svc) => (
        <a href={`#${svc.id}`} class="shrink-0 px-4 py-2 text-sm text-warm-700 hover:text-navy-800 hover:bg-white rounded transition-colors">
          {svc.title}
        </a>
      ))}
      <a href="#pricing" class="shrink-0 px-4 py-2 text-sm text-gold-700 font-medium hover:bg-gold-50 rounded transition-colors">
        料金目安
      </a>
      <a href="#position" class="shrink-0 px-4 py-2 text-sm text-warm-700 hover:text-navy-800 hover:bg-white rounded transition-colors">
        加工位置
      </a>
    </div>
  </nav>

  <!-- Service sections -->
  {services.map((svc, i) => (
    <section id={svc.id} class={`py-section-sm md:py-section ${i % 2 === 0 ? '' : 'bg-warm-50'}`}>
      <div class="mx-auto max-w-[1200px] px-4 md:px-8">
        <div class="js-fade-in grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
            <img src={url(svc.image)} alt={svc.title} class="w-full aspect-video object-cover rounded-lg" loading="lazy" />
          </div>
          <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
            <span class="text-sm text-warm-500 font-light tracking-[0.2em] uppercase">{svc.en}</span>
            <h2 class="heading-accent text-xl md:text-2xl text-navy-800 mt-1 mb-4">
              <span class="gold-underline">{svc.title}</span>
            </h2>
            <p class="text-warm-700 leading-relaxed mb-6">{svc.description}</p>
            <ul class="space-y-2">
              {svc.features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-warm-700">
                  <svg class="w-5 h-5 text-gold-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- ============================================
       PRICING (料金目安)
       ============================================ -->
  <section id="pricing" class="py-section-sm md:py-section bg-gold-50">
    <div class="mx-auto max-w-[1200px] px-4 md:px-8">
      <SectionHeading en="Pricing" ja="料金の目安" />
      <!-- Estimator CTA -->
      <div class="js-fade-in bg-white border-2 border-gold-400 rounded-lg p-6 text-center -mt-6 mb-10 max-w-lg mx-auto">
        <p class="text-navy-800 font-bold mb-2">条件を選ぶだけで概算がわかります</p>
        <a href={url("/estimate")} class="inline-flex items-center px-6 py-3 bg-gold-500 text-navy-950 font-medium rounded tracking-wider hover:bg-gold-400 transition-all duration-200 hover:-translate-y-px hover:shadow-md">
          かんたん見積もりシミュレーター
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>

      <p class="text-center text-warm-600 text-sm mb-3">
        下記は参考価格（税別）です。素材・色数・デザインの複雑さにより変動します。<br class="hidden md:block" />正式な料金はお見積りにてご案内いたします。
      </p>
      <p class="text-center text-xs text-gold-700 bg-gold-100 rounded-lg py-2 px-4 max-w-md mx-auto mb-10">
        大口のご注文や継続的なお取引には割引がございます。お気軽にお問い合わせください。
      </p>

      <!-- Embroidery: Name & Text -->
      <div class="js-fade-in bg-white rounded-lg border border-warm-200 overflow-hidden mb-6">
        <div class="bg-navy-800 px-6 py-3">
          <h3 class="text-white font-medium">刺繍加工 ─ 会社名・個人名</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm min-w-[480px]">
            <thead>
              <tr class="bg-navy-50">
                <th class="px-4 py-2.5 text-left font-medium text-navy-800">内容</th>
                <th class="px-4 py-2.5 text-left font-medium text-navy-800">サイズ</th>
                <th class="px-4 py-2.5 text-right font-medium text-navy-800">単価（税別）</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-warm-100">
              <tr><td class="px-4 py-2.5 text-warm-700">会社名（5文字まで）</td><td class="px-4 py-2.5 text-warm-600">1文字1.2cm角</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">300円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">個人名 漢字（5文字まで）</td><td class="px-4 py-2.5 text-warm-600">1文字1.2cm角</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">500円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">個人名 漢字フルネーム</td><td class="px-4 py-2.5 text-warm-600">1文字1.5cm角</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">700円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">個人名 漢字フルネーム</td><td class="px-4 py-2.5 text-warm-600">1文字2cm角</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">1,000円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">個人名 漢字フルネーム</td><td class="px-4 py-2.5 text-warm-600">1文字3cm角</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">1,500円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">個人名 英字イニシャル</td><td class="px-4 py-2.5 text-warm-600">1文字1.2cm角</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">300円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">個人名 英字筆記体</td><td class="px-4 py-2.5 text-warm-600">1文字1.2cm角</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">500円</td></tr>
            </tbody>
          </table>
        </div>
        <div class="px-6 py-3 bg-warm-50 border-t border-warm-200">
          <p class="text-xs text-warm-600">※ 5文字以降：漢字+20円/文字、英字+30円/文字 ※ 金糸・銀糸：+30円 ※ 防寒服：+50円</p>
        </div>
      </div>

      <!-- Embroidery: Logo -->
      <div class="js-fade-in bg-white rounded-lg border border-warm-200 overflow-hidden mb-6" style="transition-delay: 80ms">
        <div class="bg-navy-800 px-6 py-3">
          <h3 class="text-white font-medium">刺繍加工 ─ ロゴマーク・ワンポイント</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm min-w-[480px]">
            <thead>
              <tr class="bg-navy-50">
                <th class="px-4 py-2.5 text-left font-medium text-navy-800">内容</th>
                <th class="px-4 py-2.5 text-left font-medium text-navy-800">サイズ</th>
                <th class="px-4 py-2.5 text-right font-medium text-navy-800">単価（税別）</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-warm-100">
              <tr><td class="px-4 py-2.5 text-warm-700">文字1段</td><td class="px-4 py-2.5 text-warm-600">縦1.5cm×横10cm</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">800円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">文字1段</td><td class="px-4 py-2.5 text-warm-600">縦2cm×横10cm</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">1,000円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">文字2段</td><td class="px-4 py-2.5 text-warm-600">縦5cm×横10cm</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">1,200円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">ロゴマーク大</td><td class="px-4 py-2.5 text-warm-600">縦5cm×横30cm</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">3,600円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">緑十字マーク</td><td class="px-4 py-2.5 text-warm-600">3cm角</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">400円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">番号（2桁まで）</td><td class="px-4 py-2.5 text-warm-600">3cm角</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">600円</td></tr>
              <tr><td class="px-4 py-2.5 text-warm-700">家紋</td><td class="px-4 py-2.5 text-warm-600">4cm</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">800円</td></tr>
            </tbody>
          </table>
        </div>
        <div class="px-6 py-3 bg-warm-50 border-t border-warm-200">
          <p class="text-xs text-warm-600">※ オリジナルロゴ・指定デザインは別途型代・校正代が発生します</p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- DTF pricing -->
        <div class="js-fade-in bg-white rounded-lg border border-warm-200 overflow-hidden" style="transition-delay: 160ms">
          <div class="bg-navy-800 px-6 py-3">
            <h3 class="text-white font-medium">DTF転写プリント</h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm min-w-[360px]">
              <thead>
                <tr class="bg-navy-50">
                  <th class="px-4 py-2.5 text-left font-medium text-navy-800">サイズ（mm）</th>
                  <th class="px-4 py-2.5 text-right font-medium text-navy-800">1枚単価（税別）</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-warm-100">
                <tr><td class="px-4 py-2.5 text-warm-700">50×50</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">600円</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">30×100</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">840円</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">60×100</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">1,200円</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">100×150</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">2,000円</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">150×300</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">3,000円</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">300×300</td><td class="px-4 py-2.5 text-right font-medium text-navy-800">4,200円</td></tr>
              </tbody>
            </table>
          </div>
          <div class="px-6 py-3 bg-warm-50 border-t border-warm-200 space-y-1">
            <p class="text-xs text-warm-600">※ 9枚以下：セットアップ料 1,800〜2,700円が別途</p>
            <p class="text-xs text-warm-600">※ 10〜29枚：+600円、30〜49枚：+550円、50枚〜：+500円</p>
            <p class="text-xs text-warm-600">※ 2色目以降+100円/色、金銀蛍光+100円、ナイロン+100円</p>
          </div>
        </div>

        <!-- Silk screen pricing -->
        <div class="js-fade-in bg-white rounded-lg border border-warm-200 overflow-hidden" style="transition-delay: 240ms">
          <div class="bg-navy-800 px-6 py-3">
            <h3 class="text-white font-medium">シルクスクリーンプリント（単色）</h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm min-w-[360px]">
              <thead>
                <tr class="bg-navy-50">
                  <th class="px-4 py-2.5 text-left font-medium text-navy-800">サイズ（mm）</th>
                  <th class="px-4 py-2.5 text-right font-medium text-navy-800">10〜29枚</th>
                  <th class="px-4 py-2.5 text-right font-medium text-navy-800">30〜49枚</th>
                  <th class="px-4 py-2.5 text-right font-medium text-navy-800">50枚〜</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-warm-100">
                <tr><td class="px-4 py-2.5 text-warm-700">30×100</td><td class="px-4 py-2.5 text-right text-navy-800">600円</td><td class="px-4 py-2.5 text-right text-navy-800">400円</td><td class="px-4 py-2.5 text-right text-navy-800">360円</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">60×100</td><td class="px-4 py-2.5 text-right text-navy-800">800円</td><td class="px-4 py-2.5 text-right text-navy-800">600円</td><td class="px-4 py-2.5 text-right text-navy-800">—</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">100×300</td><td class="px-4 py-2.5 text-right text-navy-800">1,800円</td><td class="px-4 py-2.5 text-right text-navy-800">—</td><td class="px-4 py-2.5 text-right text-navy-800">—</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">300×300</td><td class="px-4 py-2.5 text-right text-navy-800">3,000円</td><td class="px-4 py-2.5 text-right text-navy-800">—</td><td class="px-4 py-2.5 text-right text-navy-800">—</td></tr>
              </tbody>
            </table>
          </div>
          <div class="px-6 py-3 bg-warm-50 border-t border-warm-200 space-y-1">
            <p class="text-xs text-warm-600">※ 製版代：通常版 7,000円/版、特注版 8,000円〜/版</p>
            <p class="text-xs text-warm-600">※ 色替え代：1,000円/版（都度）</p>
            <p class="text-xs text-warm-600">※ 2色目以降+100円/色</p>
          </div>
        </div>
      </div>

      <!-- Wappen & Name pricing -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <div class="js-fade-in bg-white rounded-lg border border-warm-200 overflow-hidden" style="transition-delay: 320ms">
          <div class="bg-navy-800 px-6 py-3">
            <h3 class="text-white font-medium">ワッペン</h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-navy-50">
                  <th class="px-4 py-2.5 text-left font-medium text-navy-800">種類 / 数量</th>
                  <th class="px-4 py-2.5 text-right font-medium text-navy-800">5〜49枚</th>
                  <th class="px-4 py-2.5 text-right font-medium text-navy-800">50〜99枚</th>
                  <th class="px-4 py-2.5 text-right font-medium text-navy-800">100枚〜</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-warm-100">
                <tr><td class="px-4 py-2.5 text-warm-700">刺繍ワッペン 天地8cm</td><td class="px-4 py-2.5 text-right text-navy-800">1,200円</td><td class="px-4 py-2.5 text-right text-navy-800">1,100円</td><td class="px-4 py-2.5 text-right text-navy-800">1,000円</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">刺繍ワッペン 天地10cm</td><td class="px-4 py-2.5 text-right text-navy-800">1,500円</td><td class="px-4 py-2.5 text-right text-navy-800">1,400円</td><td class="px-4 py-2.5 text-right text-navy-800">1,300円</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">プリントワッペン 天地8cm</td><td class="px-4 py-2.5 text-right text-navy-800">800円</td><td class="px-4 py-2.5 text-right text-navy-800">700円</td><td class="px-4 py-2.5 text-right text-navy-800">600円</td></tr>
                <tr><td class="px-4 py-2.5 text-warm-700">プリントワッペン 天地10cm</td><td class="px-4 py-2.5 text-right text-navy-800">1,000円</td><td class="px-4 py-2.5 text-right text-navy-800">900円</td><td class="px-4 py-2.5 text-right text-navy-800">800円</td></tr>
