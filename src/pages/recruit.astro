---
import Layout from '../layouts/Layout.astro'
import SectionHeading from '../components/SectionHeading.astro'

const points = [
  {
    title: '未経験からスタートできる',
    description: '先輩スタッフが丁寧に指導します。刺繍やプリントの知識がなくても、一から学べる環境です。',
    icon: 'M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5',
  },
  {
    title: 'ものづくりに集中できる',
    description: '自社工場内での作業が中心。一つひとつの製品に向き合い、技術を磨ける環境です。',
    icon: 'M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25',
  },
  {
    title: '安定した働き方',
    description: '創業65年の安定した経営基盤。日曜・祭日休み、定時退社が基本のワークスタイルです。',
    icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  },
]

const jobInfo = [
  { label: '職種', value: '刺繍加工オペレーター / プリント加工スタッフ' },
  { label: '雇用形態', value: '正社員 / パート・アルバイト' },
  { label: '勤務地', value: '〒309-1106 茨城県筑西市新治2001-4（JR新治駅 徒歩2分）' },
  { label: '勤務時間', value: 'AM9:00〜17:45' },
  { label: '休日', value: '日曜・祭日・土曜（不定期）' },
  { label: '待遇', value: '各種社会保険完備、交通費支給、車通勤可（駐車場あり）' },
]
import { url } from '../utils/paths'
---

<Layout title="採用情報｜タグチ刺繍ネーム有限会社">

  <section class="relative h-48 md:h-64 flex items-center">
    <div class="absolute inset-0">
      <img src={url("/images/facility/factory-work-01.jpg")} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-navy-800/70"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-8 w-full">
      <p class="text-sm text-gold-300 tracking-[0.2em] uppercase mb-2">Recruit</p>
      <h1 class="heading-accent text-2xl md:text-4xl text-white">採用情報</h1>
    </div>
  </section>

  <!-- Message -->
  <section class="py-section-sm md:py-section">
    <div class="mx-auto max-w-[800px] px-4 md:px-8 text-center">
      <div class="js-fade-in">
        <h2 class="heading-accent text-xl md:text-2xl text-navy-800 mb-6">
          モノづくりが好きな方へ
        </h2>
        <p class="text-warm-700 leading-relaxed max-w-lg mx-auto">
          私たちは「人に喜ばれるものづくり」を理念に、
          日々の業務に充実感と誇りを持てる職場を目指しています。
          刺繍やプリントの経験がなくても大丈夫。
          「手を動かすのが好き」「コツコツ作業が得意」──
          そんな方を歓迎します。
        </p>
      </div>
    </div>
  </section>

  <!-- Points -->
  <section class="py-section-sm md:py-section bg-warm-50">
    <div class="mx-auto max-w-[1200px] px-4 md:px-8">
      <SectionHeading en="Why Taguchi?" ja="働く魅力" />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {points.map((item, i) => (
          <div class="js-fade-in bg-white rounded-lg border border-warm-200 p-8 text-center" style={`transition-delay: ${i * 100}ms`}>
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-navy-50 text-navy-600 mb-5">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <h3 class="text-base font-bold text-navy-800 mb-2">{item.title}</h3>
            <p class="text-sm text-warm-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Voices (placeholder) -->
  <section class="py-section-sm md:py-section">
    <div class="mx-auto max-w-[1200px] px-4 md:px-8">
      <SectionHeading en="Voice" ja="社員の声" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="js-fade-in bg-warm-50 rounded-lg p-6 md:p-8 border border-warm-200">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-navy-100 flex items-center justify-center text-navy-600 font-bold">A</div>
            <div>
              <p class="font-medium text-navy-800">スタッフA</p>
              <p class="text-xs text-warm-500">刺繍加工部門・勤続8年</p>
            </div>
          </div>
          <p class="text-sm text-warm-700 leading-relaxed">
            未経験で入社しましたが、先輩に一から教えてもらいました。自分の刺繍が入った製品を街で見かけると、やりがいを感じます。
          </p>
        </div>
        <div class="js-fade-in bg-warm-50 rounded-lg p-6 md:p-8 border border-warm-200" style="transition-delay: 100ms">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-navy-100 flex items-center justify-center text-navy-600 font-bold">B</div>
            <div>
              <p class="font-medium text-navy-800">スタッフB</p>
              <p class="text-xs text-warm-500">プリント加工部門・勤続3年</p>
            </div>
          </div>
          <p class="text-sm text-warm-700 leading-relaxed">
            コツコツ作業するのが好きで、この仕事に向いていると思います。残業も少なく、プライベートとの両立がしやすいです。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Job Info -->
  <section class="py-section-sm md:py-section bg-navy-50">
    <div class="mx-auto max-w-[800px] px-4 md:px-8">
      <SectionHeading en="Requirements" ja="募集要項" />
      <div class="js-fade-in bg-white rounded-lg border border-warm-200 overflow-hidden">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-warm-100">
            {jobInfo.map((row) => (
              <tr>
                <th class="px-4 md:px-6 py-4 text-left font-medium text-navy-800 bg-navy-50 w-28 md:w-36 align-top">{row.label}</th>
                <td class="px-4 md:px-6 py-4 text-warm-800">{row.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-section-sm md:py-section bg-navy-800">
    <div class="mx-auto max-w-[800px] px-4 md:px-8 text-center">
      <div class="js-fade-in">
        <h2 class="heading-accent text-xl md:text-2xl text-white mb-3">ご応募・ご質問はこちら</h2>
        <p class="text-navy-200 text-sm mb-6">まずはお気軽にご連絡ください。見学も歓迎です。</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={url("/contact")} class="inline-flex items-center px-8 py-3.5 bg-gold-500 text-navy-950 font-medium rounded tracking-wider hover:bg-gold-400 transition-all duration-200 hover:-translate-y-px hover:shadow-md">
            応募・お問い合わせ
            <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="tel:0296-57-2644" class="inline-flex items-center gap-2 text-white hover:text-gold-300 transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            <span class="font-medium">0296-57-2644</span>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
