---
import Layout from '../layouts/Layout.astro'
import SectionHeading from '../components/SectionHeading.astro'
import Philosophy from '../components/Philosophy.astro'

const companyInfo = [
  { label: '社名', value: 'タグチ刺繍ネーム有限会社' },
  { label: '所在地', value: '〒309-1106 茨城県筑西市新治2001-4' },
  { label: '電話番号', value: '0296-57-2644' },
  { label: 'FAX', value: '0296-57-5224' },
  { label: 'アクセス', value: 'JR水戸線 新治駅 徒歩2分' },
  { label: '営業時間', value: 'AM9:00〜17:45' },
  { label: '休日', value: '日曜・祭日・土曜（不定期）' },
  { label: '事業内容', value: '刺繍加工、プリント加工、ワッペン製作、ネーム加工' },
]

const history = [
  { year: '1960年', event: '創業' },
  { year: '1970年代', event: '刺繍機を導入し、本格的な刺繍加工事業を開始' },
  { year: '1980年代', event: '多頭式刺繍機を導入、量産体制を確立' },
  { year: '1990年代', event: 'プリント加工部門を新設' },
  { year: '2000年代', event: 'レーザー加工機導入、ワッペン製作を本格化' },
  { year: '2010年代', event: 'DTFプリンター導入、小ロット対応を強化' },
  { year: '2025年', event: '経営理念を策定、新たなステージへ' },
]
import { url } from '../utils/paths'
---

<Layout title="会社案内｜タグチ刺繍ネーム有限会社">

  <!-- Hero -->
  <section class="relative h-48 md:h-64 flex items-center">
    <div class="absolute inset-0">
      <img src={url("/images/facility/factory-work-01.jpg")} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-navy-800/70"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-8 w-full">
      <p class="text-sm text-gold-300 tracking-[0.2em] uppercase mb-2">About</p>
      <h1 class="heading-accent text-2xl md:text-4xl text-white">会社案内</h1>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-section-sm md:py-section">
    <div class="mx-auto max-w-[800px] px-4 md:px-8">
      <SectionHeading en="Philosophy" ja="経営理念" />
      <div class="js-fade-in">
        <Philosophy />
      </div>
    </div>
  </section>

  <!-- Company Info -->
  <section class="py-section-sm md:py-section bg-warm-50">
    <div class="mx-auto max-w-[800px] px-4 md:px-8">
      <SectionHeading en="Company" ja="会社概要" />
      <div class="js-fade-in bg-white rounded-lg border border-warm-200 overflow-hidden">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-warm-100">
            {companyInfo.map((row) => (
              <tr>
                <th class="px-4 md:px-6 py-4 text-left font-medium text-navy-800 bg-navy-50 w-32 md:w-40 align-top">{row.label}</th>
                <td class="px-4 md:px-6 py-4 text-warm-800">{row.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Access -->
  <section class="py-section-sm md:py-section">
    <div class="mx-auto max-w-[800px] px-4 md:px-8">
      <SectionHeading en="Access" ja="アクセス" />
      <div class="js-fade-in rounded-lg overflow-hidden border border-warm-200">
        <iframe
          src="https://www.google.com/maps?q=%E8%8C%A8%E5%9F%8E%E7%9C%8C%E7%AD%91%E8%A5%BF%E5%B8%82%E6%96%B0%E6%B2%BB2001-4&output=embed"
          width="100%"
          height="350"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="タグチ刺繍ネーム 所在地"
        ></iframe>
      </div>
      <p class="mt-3 text-sm text-warm-600">JR水戸線 新治駅より徒歩2分。お車でお越しの場合は駐車場がございます。</p>
    </div>
  </section>

  <!-- History -->
  <section class="py-section-sm md:py-section bg-navy-50">
    <div class="mx-auto max-w-[800px] px-4 md:px-8">
      <SectionHeading en="History" ja="沿革" />
      <div class="relative">
        <div class="absolute left-[72px] md:left-[100px] top-0 bottom-0 w-px bg-warm-300"></div>
        <div class="space-y-6">
          {history.map((item, i) => (
            <div class="js-fade-in flex items-start gap-4 md:gap-6" style={`transition-delay: ${i * 60}ms`}>
              <span class="shrink-0 w-[60px] md:w-[84px] text-right heading-accent text-sm md:text-base text-navy-800">{item.year}</span>
              <div class="relative mt-1.5">
                <div class="w-3 h-3 rounded-full bg-gold-500 border-2 border-white shadow-sm"></div>
              </div>
              <p class="text-sm md:text-base text-warm-800 pt-0.5">{item.event}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-section-sm md:py-section bg-navy-800">
    <div class="mx-auto max-w-[800px] px-4 md:px-8 text-center">
      <div class="js-fade-in">
        <h2 class="heading-accent text-xl md:text-2xl text-white mb-3">お問い合わせ</h2>
        <p class="text-navy-200 text-sm mb-6">ご質問やご相談はお気軽にどうぞ。</p>
        <a href={url("/contact")} class="inline-flex items-center px-8 py-3.5 bg-gold-500 text-navy-950 font-medium rounded tracking-wider hover:bg-gold-400 transition-all duration-200 hover:-translate-y-px hover:shadow-md">
          お問い合わせ
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

</Layout>
