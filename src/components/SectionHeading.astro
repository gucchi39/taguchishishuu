---
interface Props {
  en: string
  ja: string
  align?: 'left' | 'center'
}

const { en, ja, align = 'center' } = Astro.props
const alignClass = align === 'center' ? 'text-center' : 'text-left'
---

<div class={`${alignClass} mb-10 md:mb-14`}>
  <span class="block text-sm text-warm-500 font-light tracking-[0.2em] uppercase mb-1">
    {en}
  </span>
  <h2 class="heading-accent text-2xl md:text-[2rem] text-navy-800 leading-snug">
    <span class="gold-underline">{ja}</span>
  </h2>
</div>
